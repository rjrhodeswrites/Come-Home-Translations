translate spanish loveinterestmontage_c5e0562a:

    # wt "I was motivated."
    wt "Estaba motivado."

# game/Scenes/Update20/loveinterestmontage.rpy:224
translate spanish loveinterestmontage_ccb1fefb:

    # pc "So, I could talk to my dad? Or anyone else that I met there?"
    pc "Entonces, ¿podría hablar con mi padre? ¿O con cualquier otra persona que conociera allí?"

# game/Scenes/Update20/loveinterestmontage.rpy:225
translate spanish loveinterestmontage_85724e3f:

    # wt "Theoretically. They don't have any way to speak back though. Yet."
    wt "En teoría. Aunque ellos no tienen forma de responder. Todavía."

# game/Scenes/Update20/loveinterestmontage.rpy:226
translate spanish loveinterestmontage_b0652138:

    # wt "Is that something that you'd want to do?"
    wt "¿Es eso algo que te gustaría hacer?"

# game/Scenes/Update20/loveinterestmontage.rpy:227
translate spanish loveinterestmontage_5b22d737:

    # pc "Maybe."
    pc "Quizás."

# game/Scenes/Update20/loveinterestmontage.rpy:230
translate spanish loveinterestmontage_b67e5d2c:

    # wt "I'm not sure why you lost so much time during the return trip."
    wt "No estoy seguro de por qué perdiste tanto tiempo durante el viaje de vuelta."

# game/Scenes/Update20/loveinterestmontage.rpy:231
translate spanish loveinterestmontage_4a7e2d03:

    # wt "It seems like time moves faster over there, so less time should have passed here."
    wt "Parece que el tiempo pasa más rápido allí, así que aquí debería haber pasado menos tiempo."

# game/Scenes/Update20/loveinterestmontage.rpy:232
translate spanish loveinterestmontage_f52c90f3:

    # wt "But you had that beard when you came back and a month passed while you were gone."
    wt "Pero tenías esa barba cuando volviste y pasó un mes mientras estuviste fuera."

# game/Scenes/Update20/loveinterestmontage.rpy:235
translate spanish loveinterestmontage_522730c7:

    # wt "More studies will have to be done."
    wt "Habrá que hacer más estudios."

# game/Scenes/Update20/loveinterestmontage.rpy:236
translate spanish loveinterestmontage_7dc54a4b:

    # wt "Can I count on you to help me with them? I'd love to hire you, now that you're almost done with school."
    wt "¿Puedo contar contigo para que me ayudes con ellos? Me encantaría contratarte, ahora que casi has terminado la universidad."

# game/Scenes/Update20/loveinterestmontage.rpy:237
translate spanish loveinterestmontage_39c52a0e:

    # wt "I believe graduation is this weekend?"
    wt "Creo que la graduación es este fin de semana, ¿no?"

# game/Scenes/Update20/loveinterestmontage.rpy:240
translate spanish loveinterestmontage_38559d3f:

    # pc "Graduation!"
    pc "¡La graduación!"

# game/Scenes/Update20/loveinterestmontage.rpy:241
translate spanish loveinterestmontage_ac2fc58a:

    # pc "Fuck..."
    pc "Joder..."

# game/Scenes/Update20/loveinterestmontage.rpy:245
translate spanish loveinterestmontage_05caf076:

    # et "You missed some assignments and the final..."
    et "Te has perdido algunos trabajos y el examen final..."

# game/Scenes/Update20/loveinterestmontage.rpy:247
translate spanish loveinterestmontage_b3be8a82:

    # et "... but don't worry, honey, I took care of it for you."
    et "... pero no te preocupes, cariño, yo me he encargado de ello por ti."

# game/Scenes/Update20/loveinterestmontage.rpy:248
translate spanish loveinterestmontage_399bdc0f:

    # pc "Really?"
    pc "¿En serio?"

# game/Scenes/Update20/loveinterestmontage.rpy:251
translate spanish loveinterestmontage_962b180d:

    # et "Of course. You're a smart boy. I know you would have done well on them."
    et "Por supuesto. Eres un chico inteligente. Sé que lo habrías hecho bien."

# game/Scenes/Update20/loveinterestmontage.rpy:252
translate spanish loveinterestmontage_98f3ca22:

    # et "I'm not going stop you from graduating because you had something more important going on in your life for a while."
    et "No voy a impedir que te gradúes porque hayas tenido algo más importante en tu vida durante un tiempo."

# game/Scenes/Update20/loveinterestmontage.rpy:255
translate spanish loveinterestmontage_08a658e1:

    # et "Besides... I take care of you and I know you'll take care of me later."
    et "Además... yo cuido de ti y sé que tú cuidarás de mí más adelante."

# game/Scenes/Update20/loveinterestmontage.rpy:256
translate spanish loveinterestmontage_e4d26afc:

    # et "Right?"
    et "¿Verdad?"

# game/Scenes/Update20/loveinterestmontage.rpy:257
translate spanish loveinterestmontage_78bd7358:

    # pc "Damn right."
    pc "Por supuesto que sí."

# game/Scenes/Update20/loveinterestmontage.rpy:259
translate spanish loveinterestmontage_dd7b6f24:

    # et "... but if you sit and take the final real quick and you pass, you'll still be able to graduate."
    et "... pero si te sientas a hacer el examen final rápidamente y apruebas, aún podrás graduarte."

# game/Scenes/Update20/loveinterestmontage.rpy:260
translate spanish loveinterestmontage_e9e45599:

    # pc "Oh yes please, Mrs. McGee. That would be great."
    pc "Oh, sí, por favor, Sra. McGee. Eso sería genial."

# game/Scenes/Update20/loveinterestmontage.rpy:266
translate spanish loveinterestmontage_d0ae05fb:

    # et "This is very good. You'll pass."
    et "Esto está muy bien. Aprobarás."

# game/Scenes/Update20/loveinterestmontage.rpy:267
translate spanish loveinterestmontage_b6c4c749:

    # et "I knew you were a smart boy."
    et "Sabía que eras un chico inteligente."

# game/Scenes/Update20/loveinterestmontage.rpy:268
translate spanish loveinterestmontage_6f49be4e:

    # pc "Thanks so much, Mrs. McGee."
    pc "Muchas gracias, Sra. McGee."

# game/Scenes/Update20/loveinterestmontage.rpy:272
translate spanish loveinterestmontage_d08e2cf8:

    # sst "Yeah, you missed a few things..."
    sst "Sí, te has saltado algunas cosas..."

# game/Scenes/Update20/loveinterestmontage.rpy:274
translate spanish loveinterestmontage_322a44f2:

    # sst "...but I'm not going to fail you."
    sst "... pero no te voy a suspender."

# game/Scenes/Update20/loveinterestmontage.rpy:277
translate spanish loveinterestmontage_97e19796:

    # sst "I need you to graduate so that I feel less guilty about fucking you every chance I get."
    sst "Necesito que te gradúes para sentirme menos culpable por follarme contigo cada vez que puedo."

# game/Scenes/Update20/loveinterestmontage.rpy:278
translate spanish loveinterestmontage_dc418b49:

    # pc "Really? So I'm good?"
    pc "¿En serio? ¿Entonces estoy bien?"

# game/Scenes/Update20/loveinterestmontage.rpy:281
translate spanish loveinterestmontage_8e879040:

    # sst "You might have to do some private studies... but yeah, you're so good, baby."
    sst "Quizá tengas que hacer algunos estudios por tu cuenta... pero sí, lo has hecho muy bien, cariño."

# game/Scenes/Update20/loveinterestmontage.rpy:283
translate spanish loveinterestmontage_cc1fc6d9:

    # sst "... but I hate failing people, especially when I can tell that they're trying."
    sst "... pero odio suspender a la gente, sobre todo cuando veo que se esfuerzan."

# game/Scenes/Update20/loveinterestmontage.rpy:284
translate spanish loveinterestmontage_d70fddc8:

    # sst "So you're good. You'll pass."
    sst "Así que estás bien. Aprobarás."

# game/Scenes/Update20/loveinterestmontage.rpy:285
translate spanish loveinterestmontage_3484a643:

    # pc "Thanks so much, Ms. Welch."
    pc "Muchas gracias, Sra. Welch."

