# game/Scenes/CafeChats/cafechat1.rpy:6
translate spanish cafechat1_c5150887:

    # "I hang around the café for a while, looking for anybody who might be up for a chat."
    "Me quedo un rato en la cafetería, buscando a alguien con quien charlar."

# game/Scenes/CafeChats/cafechat1.rpy:8
translate spanish cafechat1_eb82cee3:

    # "A woman comes in alone and orders a coffee, then sits by herself in the corner."
    "Entra una mujer sola, pide un café y se sienta sola en un rincón."

# game/Scenes/CafeChats/cafechat1.rpy:9
translate spanish cafechat1_b6ba1c27:

    # "She's looking at her phone, but then looks up and around the room."
    "Está mirando su teléfono, pero luego levanta la vista y echa un vistazo a la sala."

# game/Scenes/CafeChats/cafechat1.rpy:10
translate spanish cafechat1_52268ea8:

    # "Our eyes meet momentarily and she smiles at me."
    "Nuestras miradas se cruzan un instante y me sonríe."

# game/Scenes/CafeChats/cafechat1.rpy:11
translate spanish cafechat1_a276a53c:

    # "I take that as a sign to go over and talk to her."
    "Lo tomo como una señal para acercarme y hablar con ella."

# game/Scenes/CafeChats/cafechat1.rpy:13
translate spanish cafechat1_7261b066:

    # "Although she smiles at me, when I start walking over towards her, she immediately seems anxious."
    "Aunque me sonríe, cuando empiezo a acercarme a ella, de inmediato parece nerviosa."

# game/Scenes/CafeChats/cafechat1.rpy:14
translate spanish cafechat1_d7a053d7:

    # pc "Hey, I just thought I'd come over and say hi. Can I get you a coffee or anything?"
    pc "Hola, solo pensé en acercarme a saludarte. ¿Te traigo un café o algo?"

# game/Scenes/CafeChats/cafechat1.rpy:15
translate spanish cafechat1_f288acdf:

    # "Woman" "Oh no, I'm sorry, I didn't mean to send you any signals."
    "Woman" "Oh, no, lo siento, no era mi intención darte ninguna señal."

# game/Scenes/CafeChats/cafechat1.rpy:16
translate spanish cafechat1_706c714c:

    # pc "Oh it's okay, I just thought maybe we could chat for a bit."
    pc "Oh, no pasa nada, solo pensé que quizá podríamos charlar un rato."

# game/Scenes/CafeChats/cafechat1.rpy:17
translate spanish cafechat1_18e49522:

    # "Woman" "No sorry, I'm not interested."
    "Woman" "No, lo siento, no me interesa."

# game/Scenes/CafeChats/cafechat1.rpy:18
translate spanish cafechat1_2974e88a:

    # pc "Not even for just a few minutes."
    pc "Ni siquiera por unos minutos."

# game/Scenes/CafeChats/cafechat1.rpy:19
translate spanish cafechat1_448eb64d:

    # "Woman" "I'm actually here with somebody."
    "Woman" "De hecho, estoy aquí con alguien."

# game/Scenes/CafeChats/cafechat1.rpy:20
translate spanish cafechat1_1f34339e:

    # "Other Woman" "Hey babe, is this guy bothering you?"
    "Other Woman" "Oye, cariño, ¿te está molestando este chico?"

# game/Scenes/CafeChats/cafechat1.rpy:25
translate spanish cafechat1_57c300a7:

    # "Another woman comes up to her and they kiss before sitting in the seat next to each other."
    "Otra mujer se acerca a ella y se besan antes de sentarse una al lado de la otra."

# game/Scenes/CafeChats/cafechat1.rpy:26
translate spanish cafechat1_fb2f4ae8:

    # pc "No, sorry to bother you. You ladies have a good day."
    pc "No, perdón por molestaros. Que tengáis un buen día, chicas."

# game/Scenes/CafeChats/cafechat1.rpy:27
translate spanish cafechat1_c4d76043:

    # "I walk away and leave them to each other."
    "Me alejo y las dejo solas."

# game/Scenes/CafeChats/cafechat1.rpy:29
translate spanish cafechat1_84475cd1:

    # "Struck out again, but at least this one was nicer than the last."
    "Otro fracaso, pero al menos esta ha sido más amable que la anterior."

# game/Scenes/CafeChats/cafechat1.rpy:35
translate spanish cafechat1_9c8103c3:

    # "I leave the café and head to class."
    "Salgo de la cafetería y me dirijo a clase."

# game/Scenes/CafeChats/cafechat1.rpy:38
translate spanish cafechat1_f5c89a33:

    # "I leave the café and head back out to my car."
    "Salgo de la cafetería y vuelvo a mi coche."

