# TODO: Translation updated at 2026-06-02 13:12

# game/Scenes/Adrian/Adrian2b.rpy:15
translate french adrian2b_fe1843ee:

    # "After work, I check the address that Adrian had sent me and put it into the GPS."
    "Après le travail, je vérifie l’adresse qu’Adrian m’a envoyée et je l’entre dans le GPS."

# game/Scenes/Adrian/Adrian2b.rpy:16
translate french adrian2b_220b39e6:

    # "It doesn't take long to get to her house. She actually lives really close to my home."
    "Je n'ai pas mis longtemps à arriver chez elle. Il s'avère qu'elle habite tout près de chez moi."

# game/Scenes/Adrian/Adrian2b.rpy:20
translate french adrian2b_614acdee:

    # "I park on the street, then walk up to the front door and knock. A woman answers almost immediately."
    "Je me gare dans la rue, puis je marche jusqu'à la porte d'entrée et je frappe. Une femme m'ouvre presque tout de suite."

# game/Scenes/Adrian/Adrian2b.rpy:21
translate french adrian2b_3dafc9b9:

    # "Woman" "Hello? Can I help you?"
    "Woman" "Bonjour ? Je peux vous aider ?"

# game/Scenes/Adrian/Adrian2b.rpy:22
translate french adrian2b_966e8fef:

    # pc "I'm looking for Adrian. Does she live here?"
    pc "Je cherche Adrian. Est-ce qu'elle habite ici ?"

# game/Scenes/Adrian/Adrian2b.rpy:23
translate french adrian2b_b542dd0a:

    # "Woman" "Yes she does."
    "Woman" "Oui, c'est ici."

# game/Scenes/Adrian/Adrian2b.rpy:24
translate french adrian2b_acfd1a5a:

    # pc "She invited me over to play some video games."
    pc "Elle m'a invité à venir jouer à des jeux vidéo."

# game/Scenes/Adrian/Adrian2b.rpy:25
translate french adrian2b_172cc6dd:

    # "Woman" "Oh she did? She didn't tell me that anybody was coming."
    "Woman" "Ah bon ? Elle ne m'a pas dit que quelqu'un allait venir."

# game/Scenes/Adrian/Adrian2b.rpy:26
translate french adrian2b_2fdb51d6:

    # "Woman" "You just stay there and I'll go get her."
    "Woman" "Restez là, je vais la chercher."

# game/Scenes/Adrian/Adrian2b.rpy:27
translate french adrian2b_cddf2662:

    # "Then, I hear footsteps coming down the stairs and Adrian calls out."
    "Puis, j’entends des pas descendre l’escalier et Adrian crie :"

# game/Scenes/Adrian/Adrian2b.rpy:28
translate french adrian2b_9899eaa9:

    # gg "He's my friend, Mom, let him in."
    gg "C’est mon ami, Maman, laisse-le entrer."

# game/Scenes/Adrian/Adrian2b.rpy:33
translate french adrian2b_c583a608:

    # "Woman" "You're supposed to tell me if somebody is coming over, Adrian."
    "Woman" "Tu es censée me prévenir quand quelqu’un vient, Adrian."

# game/Scenes/Adrian/Adrian2b.rpy:34
translate french adrian2b_6c01d4fd:

    # gg "I know, Mom. I meant to, but I was just busy... with schoolwork. I forgot."
    gg "Je sais, Maman. Je voulais le faire, mais j’étais occupée… avec mes devoirs. J’ai oublié."

# game/Scenes/Adrian/Adrian2b.rpy:35
translate french adrian2b_e878210c:

    # "Adrian's Mom" "Okay, well he can stay until 10."
    "Adrian's Mom" "D’accord, il peut rester jusqu’à 22 h."

# game/Scenes/Adrian/Adrian2b.rpy:36
translate french adrian2b_326f12bf:

    # gg "Okay, Mom. Thank you."
    gg "D'accord, Maman. Merci."

# game/Scenes/Adrian/Adrian2b.rpy:39
translate french adrian2b_8f7ebec7:

    # "I follow her inside the house and we walk up the stairs."
    "Je la suis à l'intérieur de la maison et nous montons les escaliers."

# game/Scenes/Adrian/Adrian2b.rpy:44
translate french adrian2b_d41d8cd9:

    # voice 'voices/adrian_sorry.mp3'
    voice 'voices/adrian_sorry.mp3'

# game/Scenes/Adrian/Adrian2b.rpy:45
translate french adrian2b_c03425eb:

    # gg "I'm sorry about that. She can be a bit overbearing sometimes."
    gg "Je suis désolée pour ça. Elle peut être un peu autoritaire parfois."

# game/Scenes/Adrian/Adrian2b.rpy:46
translate french adrian2b_3ed1d973:

    # gg "She's just very protective of me. Only child and all."
    gg "Elle est juste très protectrice. Je suis enfant unique, tu vois."

# game/Scenes/Adrian/Adrian2b.rpy:49
translate french adrian2b_04c7f126:

    # pc "My dad could be the same way sometimes when I was growing up. I'm an only child too."
    pc "Mon père pouvait être pareil parfois quand j'étais petit. Je suis enfant unique moi aussi."

# game/Scenes/Adrian/Adrian2b.rpy:50
translate french adrian2b_f7e6c62b:

    # gg "Then you understand."
    gg "Alors tu comprends."

# game/Scenes/Adrian/Adrian2b.rpy:52
translate french adrian2b_636661b2:

    # gg "It does sometimes."
    gg "Oui, parfois."

# game/Scenes/Adrian/Adrian2b.rpy:53
translate french adrian2b_2900eca8:

    # gg "But I love her and she's been really good to me through a lot of hard times."
    gg "Mais je l'aime et elle a été vraiment gentille avec moi pendant plein de moments difficiles."

# game/Scenes/Adrian/Adrian2b.rpy:54
translate french adrian2b_c07d0332:

    # pc "That's good. Always good to have people there for you."
    pc "C'est bien. C'est toujours bien d'avoir des gens là pour toi."

# game/Scenes/Adrian/Adrian2b.rpy:55
translate french adrian2b_a560b57e:

    # gg "Want to check out the game?"
    gg "Tu veux jeter un œil au jeu ?"

# game/Scenes/Adrian/Adrian2b.rpy:56
translate french adrian2b_39757b54:

    # pc "Yeah, let's do it."
    pc "Ouais, allons-y."

# game/Scenes/Adrian/Adrian2b.rpy:59
translate french adrian2b_5c242d3c:

    # gg "Okay, so this is my character. Her name is Trenoxa and she's a mage."
    gg "Bon, voilà mon personnage. Elle s'appelle Trenoxa et c'est une mage."

# game/Scenes/Adrian/Adrian2b.rpy:60
translate french adrian2b_290fa501:

    # pc "She looks badass."
    pc "Elle a l'air d'une dure à cuire."

# game/Scenes/Adrian/Adrian2b.rpy:61
translate french adrian2b_eecdf621:

    # gg "Oh she definitely is. Watch me kill all these kobolds."
    gg "Oh, elle l'est carrément. Regarde-moi tuer tous ces kobolds."

# game/Scenes/Adrian/Adrian2b.rpy:66
translate french adrian2b_8a0ec2b0:

    # "Using the keyboard and mouse, she guides her character into the middle of a group of small monsters and proceeds to blow them all up."
    "À l'aide du clavier et de la souris, elle guide son personnage au milieu d'un groupe de petits monstres et les fait tous exploser."

# game/Scenes/Adrian/Adrian2b.rpy:68
translate french adrian2b_c9d9899a:

    # "I barely look at the screen, unable to take my eyes off of her."
    "Je regarde à peine l'écran, incapable de détacher mon regard d'elle."

# game/Scenes/Adrian/Adrian2b.rpy:69
translate french adrian2b_c68ec5f4:

    # "She really gets into this stuff, and it's cute to see her so excited about it."
    "Elle se prend vraiment au jeu, et c'est mignon de la voir aussi enthousiaste."

# game/Scenes/Adrian/Adrian2b.rpy:72
translate french adrian2b_f57aeacc:

    # gg "Do you want to give it a try?"
    gg "Tu veux essayer ?"

# game/Scenes/Adrian/Adrian2b.rpy:73
translate french adrian2b_e3e97310:

    # pc "What if I get your character killed?"
    pc "Et si jamais je fais mourir ton personnage ?"

# game/Scenes/Adrian/Adrian2b.rpy:74
translate french adrian2b_03db2857:

    # gg "It's no big deal. You just revive at the nearest respawn point and are weakened for a few minutes."
    gg "C’est pas grave. Tu vas juste ressusciter au respawn le plus proche et tu seras affaibli pendant quelques minutes."

# game/Scenes/Adrian/Adrian2b.rpy:75
translate french adrian2b_9a5eb084:

    # gg "Come on, give it a try, see if you like it."
    gg "Allez, essaie, tu verras si ça te plaît."

# game/Scenes/Adrian/Adrian2b.rpy:76
translate french adrian2b_63023601:

    # pc "Okay."
    pc "D’accord."

# game/Scenes/Adrian/Adrian2b.rpy:79
translate french adrian2b_2d53ff69:

    # "We switch seats and I play for a bit, trying to learn all the buttons."
    "On échange nos places et je joue un peu, en essayant d’apprendre toutes les touches."

# game/Scenes/Adrian/Adrian2b.rpy:80
translate french adrian2b_b0a6ba6f:

    # gg "Okay, all of your powers are the number keys up top. You move with WASD and look around with the mouse."
    gg "Bon, tous tes pouvoirs sont sur les touches numériques en haut. Tu te déplaces avec ZQSD et tu regardes autour de toi avec la souris."

# game/Scenes/Adrian/Adrian2b.rpy:81
translate french adrian2b_3b25da4f:

    # gg "Just click on what you want to kill and then use one of your powers to kill it."
    gg "T'as juste à cliquer sur ta cible, puis utiliser un de tes pouvoirs pour l'éliminer."

# game/Scenes/Adrian/Adrian2b.rpy:82
translate french adrian2b_b4a8a49d:

    # gg "Super easy. Barely an inconvenience."
    gg "Super facile. Ça va tout seul."

# game/Scenes/Adrian/Adrian2b.rpy:83
translate french adrian2b_babb66b4:

    # pc "You say that, but I'm still wondering what a WASD is."
    pc "Tu dis ça, mais j'en suis encore au ZQSD."

# game/Scenes/Adrian/Adrian2b.rpy:86
translate french adrian2b_055f2992:

    # "A little bit later, I have pretty much figured out the controls and am demolishing enemies."
    "Un peu plus tard, j'ai à peu près compris les commandes et je démolis les ennemis."

# game/Scenes/Adrian/Adrian2b.rpy:87
translate french adrian2b_4915d075:

    # gg "You like it?"
    gg "Tu aimes ça ?"

# game/Scenes/Adrian/Adrian2b.rpy:88
translate french adrian2b_3b7f3448:

    # pc "I have to admit, it's pretty fun."
    pc "Je dois admettre que c'est plutôt sympa."

# game/Scenes/Adrian/Adrian2b.rpy:89
translate french adrian2b_a82592f5:

    # gg "I'm glad. If you bought a copy sometime, we could even play together."
    gg "Tant mieux. Si tu l'achètes un de ces jours, on pourrait même y jouer ensemble."

# game/Scenes/Adrian/Adrian2b.rpy:90
translate french adrian2b_c0437e5d:

    # pc "That would be fun."
    pc "Ce serait sympa."

# game/Scenes/Adrian/Adrian2b.rpy:93
translate french adrian2b_ee920117:

    # gg "I think so too. I'd love to explore and kill goblins with you."
    gg "Je crois aussi. J'adorerais explorer et tuer des gobelins avec toi."

# game/Scenes/Adrian/Adrian2b.rpy:94
translate french adrian2b_efa756f8:

    # pc "Maybe I'll get it sometime then."
    pc "Je vais peut-être me le procurer un de ces jours, alors."

# game/Scenes/Adrian/Adrian2b.rpy:95
translate french adrian2b_ce14f6da:

    # gg "Good."
    gg "Bien."

# game/Scenes/Adrian/Adrian2b.rpy:96
translate french adrian2b_6a346fe1:

    # gg "It's about time for you to go. I wouldn't mind hanging out longer, but it's nearly 10 and my mom will be mad."
    gg "Il est presque l'heure pour toi de partir. Ça me dérangerait pas qu'on traîne plus longtemps, mais il est presque 22h et ma mère va se fâcher."

# game/Scenes/Adrian/Adrian2b.rpy:97
translate french adrian2b_8f70c6ec:

    # pc "Okay, I'll go then. Don't want to get you in trouble."
    pc "D'accord, je vais y aller alors. Je veux pas te causer d'ennuis."

# game/Scenes/Adrian/Adrian2b.rpy:98
translate french adrian2b_45175d50:

    # gg "I had a good time though. Thank you for coming over."
    gg "J'ai quand même passé un bon moment. Merci d'être venu."

# game/Scenes/Adrian/Adrian2b.rpy:99
translate french adrian2b_1b5489ad:

    # pc "Thanks for inviting me, I had fun too."
    pc "Merci de m'avoir invité, je me suis bien amusé aussi."

# game/Scenes/Adrian/Adrian2b.rpy:103
translate french adrian2b_6a658ffa:

    # "She walks me down to the front door."
    "Elle m'accompagne jusqu'à la porte d'entrée."

# game/Scenes/Adrian/Adrian2b.rpy:104
translate french adrian2b_2c7e0e7e:

    # gg "I could probably get you a copy of the game. If I did, would you play with me?"
    gg "Je pourrais probablement te trouver un exemplaire du jeu. Si je le faisais, tu jouerais avec moi ?"

# game/Scenes/Adrian/Adrian2b.rpy:105
translate french adrian2b_7f0c6c37:

    # pc "Yeah, I think I could do that."
    pc "Ouais, y a moyen."

# game/Scenes/Adrian/Adrian2b.rpy:107
translate french adrian2b_d41d8cd9_1:

    # voice 'voices/adrian_seeyou.mp3'
    voice 'voices/adrian_seeyou.mp3'

# game/Scenes/Adrian/Adrian2b.rpy:108
translate french adrian2b_c8b2cdfc:

    # gg "Okay cool. I'll see you in class, [pcname]."
    gg "OK, cool. On se voit en cours, [pcname]."

# game/Scenes/Adrian/Adrian2b.rpy:109
translate french adrian2b_9bfc226b:

    # pc "Alright. Bye, Adrian."
    pc "D'accord. Salut, Adrian."

