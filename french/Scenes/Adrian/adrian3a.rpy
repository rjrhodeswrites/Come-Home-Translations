    # gg "Yeah, I bought you a copy of Souls of War, so you could play with me sometime."
    gg "Ouais, je t'ai acheté un exemplaire de Souls of War, qu'on puisse jouer un de ces jours."

# game/Scenes/Adrian/adrian3a.rpy:18
translate french adrian3a_7c430bc8:

    # pc "You didn't have to do that."
    pc "T'étais pas obligée de faire ça."

# game/Scenes/Adrian/adrian3a.rpy:20
translate french adrian3a_6012fac8:

    # gg "I know, but I really wanted to play with you and I thought this might speed things along."
    gg "Je sais, mais j'avais vraiment envie de jouer avec toi et j'ai pensé que ça irait plus vite comme ça."

# game/Scenes/Adrian/adrian3a.rpy:21
translate french adrian3a_2f8b1c2b:

    # gg "Here, just take the code and go to the website."
    gg "Tiens, c'est un code à entrer sur le site web."

# game/Scenes/Adrian/adrian3a.rpy:22
translate french adrian3a_e56fb6fb:

    # pc "Thanks. I'll have to pay you back sometime."
    pc "Merci. Je te rembourserai un de ces jours."

