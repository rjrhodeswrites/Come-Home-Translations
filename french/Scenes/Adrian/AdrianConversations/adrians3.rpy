# game/Scenes/Adrian/AdrianConversations/adrians3.rpy:44
translate french adrians3_324d4d69:

    # gg "Like I'm doing something wrong."
    gg "Comme si je faisais quelque chose de mal."

# game/Scenes/Adrian/AdrianConversations/adrians3.rpy:45
translate french adrians3_e090187a:

    # pc "Sorry. That sucks."
    pc "Désolé. Ça craint."

