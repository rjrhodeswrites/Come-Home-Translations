translate french adrian15_c75ca3d4:

    # gg "You wish."
    gg "Tu rêves."

# game/Scenes/Adrian/adrian15.rpy:213
translate french adrian15_9882e4ae:

    # ath "We might have time to fit in a quick game, if we hurry. It won't take me long to wipe the floor with you."
    ath "On aura peut-être le temps de caser une petite partie, si on se dépêche. Je vais te mettre K.O en deux-deux."

# game/Scenes/Adrian/adrian15.rpy:214
translate french adrian15_36bb3cc8:

    # gg "Let's go then, bitch!"
    gg "Ha ! Je vais te dégommer !"

# game/Scenes/Adrian/adrian15.rpy:217
translate french adrian15_b7c027eb:

    # "Just then, a police car parks in front of the house and a man in a suit steps out, looking grim and official."
    "À ce moment-là, une voiture de police se gare devant la maison et un homme en costume en sort, l'air sévère et officiel."

# game/Scenes/Adrian/adrian15.rpy:218
translate french adrian15_b3e6504f:

    # ath "Rain check, I guess. Time to go."
    ath "Ah, on remet ça à plus tard,. Il est temps de partir."

# game/Scenes/Adrian/adrian15.rpy:221
translate french adrian15_d5f4dd84:

    # ath "I love you, cuz. I'll see you again soon."
    ath "Je t'aime, cousine. On se reverra bientôt."

# game/Scenes/Adrian/adrian15.rpy:222
translate french adrian15_b13e0d25:

    # gg "I love you too."
    gg "Je t'aime aussi."

# game/Scenes/Adrian/adrian15.rpy:223
translate french adrian15_96dc14b2:

    # gg "I hate this so much. I don't want to let you go."
    gg "Ça me fout en rage. Je veux pas te laisser partir."

# game/Scenes/Adrian/adrian15.rpy:224
translate french adrian15_1edb5510:

    # ath "I know. We'll be okay though."
    ath "Je sais. Mais tout ira bien."

# game/Scenes/Adrian/adrian15.rpy:225
translate french adrian15_e2fe510e:

    # ath "And when I see you again, we'll hang out for days, okay?"
    ath "Et quand je te reverrai, on passera des jours ensemble, d'accord ?"

# game/Scenes/Adrian/adrian15.rpy:226
translate french adrian15_c5cc5eaf:

    # gg "Okay, but if there's anything I can do to help, please call me."
    gg "D'accord, mais s'il y a quoi que ce soit que je puisse faire pour aider, appelle-moi."

# game/Scenes/Adrian/adrian15.rpy:227
translate french adrian15_20fcca99:

    # ath "I will."
    ath "Ça marche."

# game/Scenes/Adrian/adrian15.rpy:230
translate french adrian15_170b7c68:

    # ath "And [pcname], it was nice to meet you."
    ath "Et [pcname], ravie de t'avoir rencontrée."

# game/Scenes/Adrian/adrian15.rpy:231
translate french adrian15_61906ded:

    # pc "Nice to meet you too, Athena."
    pc "Ravi aussi, Athena."

# game/Scenes/Adrian/adrian15.rpy:235
translate french adrian15_84825cda:

    # "Suddenly, she pulls my hand, yanking me closer, then whispers in my ear."
    "Soudain, elle me tire par la main, m'attirant vers elle, puis me chuchote à l'oreille."

# game/Scenes/Adrian/adrian15.rpy:236
translate french adrian15_46517656:

    # ath "Be good to her. If you hurt my cousin, I will find you."
    ath "Sois gentil avec elle. Si tu fais du mal à ma cousine, je te retrouverai."

# game/Scenes/Adrian/adrian15.rpy:237
translate french adrian15_17a1cb32:

    # pc "Uh, I will."
    pc "Euh, c'est noté."

# game/Scenes/Adrian/adrian15.rpy:240
translate french adrian15_05763882:

    # ath "Bye, Adrian! Love you!"
    ath "Au revoir, Adrian ! Je t'aime !"

# game/Scenes/Adrian/adrian15.rpy:241
translate french adrian15_11b6245f:

    # gg "Bye! Love you too!"
    gg "Au revoir ! Je t'aime aussi !"

# game/Scenes/Adrian/adrian15.rpy:242
translate french adrian15_fd99ecee:

    # ath "Tell your mom I love her too!"
    ath "Dis à ta maman que je l'aime aussi !"

# game/Scenes/Adrian/adrian15.rpy:243
translate french adrian15_b909935e:

    # gg "I will!"
    gg "T'inquiète !"

# game/Scenes/Adrian/adrian15.rpy:244
translate french adrian15_124dcc1b:

    # ath "I'll kick your pink Kirby ass real soon!"
    ath "Je vais bientôt te botter ton petit cul rose de Kirby !"

# game/Scenes/Adrian/adrian15.rpy:248
translate french adrian15_4829e0da:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns towards me, tears in her eyes."
    "Dès qu’Athéna est dans la voiture et que celle-ci commence à s’éloigner, Adrian se tourne vers moi, les larmes aux yeux."

# game/Scenes/Adrian/adrian15.rpy:249
translate french adrian15_5928d159:

    # gg "Ugh, this fucking sucks."
    gg "Bordel, c'est pas juste."

# game/Scenes/Adrian/adrian15.rpy:250
translate french adrian15_72615de3:

    # gg "I'm sorry, [pcname]. I don't much feel like playing games anymore."
    gg "Je suis désolée, [pcname]. J’ai plus vraiment envie de jouer."

# game/Scenes/Adrian/adrian15.rpy:251
translate french adrian15_fd83325a:

    # gg "I'll see you later, okay?"
    gg "On se voit plus tard, d’accord ?"

# game/Scenes/Adrian/adrian15.rpy:252
translate french adrian15_e576c8b5:

    # pc "Are you going to be all right."
    pc "Tu vas t’en sortir ?"

# game/Scenes/Adrian/adrian15.rpy:253
translate french adrian15_0da71ea1:

    # gg "Yeah. I'll have to be."
    gg "Ouais. Il faudra bien."

# game/Scenes/Adrian/adrian15.rpy:254
translate french adrian15_4004410a:

    # gg "But I need some time alone now."
    gg "Mais j’ai besoin d’être seule maintenant."

# game/Scenes/Adrian/adrian15.rpy:255
translate french adrian15_b21f0baf:

    # pc "No problem. Let me know if I can help. See you later, Adrian."
    pc "Pas de problème. Dis-moi si je peux t'aider. À plus tard, Adrian."

# game/Scenes/Adrian/adrian15.rpy:256
translate french adrian15_9d092ee2:

    # gg "Thanks, [pcname]. See ya."
    gg "Merci, [pcname]. À plus."

# game/Scenes/Adrian/adrian15.rpy:259
translate french adrian15_25d8780e:

    # "I leave Adrian's house, hoping that she'll be okay."
    "Je quitte la maison d'Adrian, en espérant qu'elle ira bien."

# game/Scenes/Adrian/adrian15.rpy:267
translate french adrian15_d9f27044:

    # "As soon as Athena is in the car and it starts to pull away, Adrian turns and collapses into my arms, crying against my shoulder."
    "Dès qu'Athena est dans la voiture et que celle-ci commence à s'éloigner, Adrian se retourne et s'effondre dans mes bras, pleurant contre mon épaule."

# game/Scenes/Adrian/adrian15.rpy:268
translate french adrian15_0e12d7d2:

    # gg "This fucking sucks!!!"
    gg "Aaaaaaaaah !!!"

# game/Scenes/Adrian/adrian15.rpy:269
translate french adrian15_182f9ad8:

    # "I rub her back and hold her and let her cry it out."
    "Je lui caresse le dos, je la serre contre moi et je la laisse pleurer un bon coup."

# game/Scenes/Adrian/adrian15.rpy:272
translate french adrian15_8bf9515c:

    # "A few minutes later, she sniffs up her tears and looks at me."
    "Quelques minutes plus tard, elle renifle pour sécher ses larmes et me regarde."

# game/Scenes/Adrian/adrian15.rpy:273
translate french adrian15_3d955406:

    # gg "Okay, feeling slightly better."
    gg "Je me sens un peu mieux."

# game/Scenes/Adrian/adrian15.rpy:274
translate french adrian15_58a70a56:

    # gg "I want to go for a ride. Do you want to come with me?"
    gg "J'ai envie d'aller faire un tour. Tu veux venir avec moi ?"

# game/Scenes/Adrian/adrian15.rpy:275
translate french adrian15_2b3b24ff:

    # "I think I probably should stay with her, with how upset she is."
    "Je crois que je devrais rester avec elle, vu comme elle est bouleversée."

# game/Scenes/Adrian/adrian15.rpy:276
translate french adrian15_2d17893f:

    # pc "Sure, let's do it, if you're okay to drive?"
    pc "Bien sûr, allons-y, si tu te sens capable de conduire ?"

# game/Scenes/Adrian/adrian15.rpy:277
translate french adrian15_28404c62:

    # gg "Yeah, I'm okay."
    gg "Ouais, ça va."

# game/Scenes/Adrian/adrian15.rpy:280
translate french adrian15_58afc396:

    # gg "Here, I found her old helmet in the storage under the seat. You should probably wear it."
    gg "Tiens, j’ai trouvé son vieux casque dans le coffre sous la selle. Tu devrais sans doute le mettre."

# game/Scenes/Adrian/adrian15.rpy:281
translate french adrian15_4fb22de7:

    # pc "Dear lord, this thing is huge."
    pc "Bon sang, ce truc est énorme."

# game/Scenes/Adrian/adrian15.rpy:282
translate french adrian15_2409eb5c:

    # gg "That's what she... nevermind, let's just go."
    gg "That's what she... laisse tomber, allons-y."

# game/Scenes/Adrian/adrian15.rpy:283
translate french adrian15_9b4e9f4c:

    # pc "You know how to ride this thing?"
    pc "Tu sais conduire ce truc ?"

# game/Scenes/Adrian/adrian15.rpy:284
translate french adrian15_12315e04:

    # gg "Yeah, Athena taught me when I visited her last time. We rode all over the place on it."
    gg "Ouais, Athéna m’a appris quand je lui ai rendu visite la dernière fois. On a sillonné toute la région avec."

# game/Scenes/Adrian/adrian15.rpy:285
translate french adrian15_c4bccc9f:

    # gg "I'm the only person she'd ever let drive it."
    gg "Y a qu'à moi qu'elle a laissé conduire cette moto."

# game/Scenes/Adrian/adrian15.rpy:289
translate french adrian15_65c8468c:

    # "I wrap my arms around her and hold on as she pulls out into the street."
    "Je passe mes bras autour d’elle et m’accroche alors qu’elle s’engage sur la route."

# game/Scenes/Adrian/adrian15.rpy:290
translate french adrian15_a4cc4d56:

    # pc "Where are we going?"
    pc "Où on va ?"

# game/Scenes/Adrian/adrian15.rpy:291
translate french adrian15_33da7917:

    # gg "I just feel like riding for a while. Clear my head, you know."
    gg "J’ai juste envie de rouler. Pour me vider la tête, tu vois."

# game/Scenes/Adrian/adrian15.rpy:292
translate french adrian15_61f77a4c:

    # pc "Sure."
    pc "D’accord."

# game/Scenes/Adrian/adrian15.rpy:294
translate french adrian15_df03bfba:

    # "It feels like we're riding forever. We leave town and take a rarely used highway out towards the lake."
    "J’ai l’impression qu’on roule depuis une éternité. On quitte la ville et on prend une autoroute peu fréquentée en direction du lac."

# game/Scenes/Adrian/adrian15.rpy:295
translate french adrian15_ba48df36:

    # "After a while, I'm not even sure where we are anymore. Hopefully Adrian knows. I guess I have GPS on the phone if we get lost."
    "Au bout d’un moment, je ne sais même plus où on est. J’espère qu’Adrian sait. Et puis dans le pire des cas, j’ai le GPS sur mon téléphone."

# game/Scenes/Adrian/adrian15.rpy:296
translate french adrian15_0bac7b03:

    # "But I don't say anything. I just hold on and let Adrian clear her mind of everything."
    "Mais je ne dis rien. Je m’accroche simplement et laisse Adrian se vider l’esprit."

# game/Scenes/Adrian/adrian15.rpy:297
translate french adrian15_76cd1d73:

    # "She seems calm now, like this is exactly what she needed to get through this."
    "Elle a l’air calme maintenant, comme si c’était exactement ce qu'il lui fallait pour surmonter ça."

# game/Scenes/Adrian/adrian15.rpy:298
translate french adrian15_f0b56a2e:

    # "Then, after what must have been at least an hour, she pulls off the highway and drives a little ways up towards the cliffside near the lake."
    "Puis, après au moins une heure, elle quitte l’autoroute et monte un peu vers la falaise près du lac."

# game/Scenes/Adrian/adrian15.rpy:301
translate french adrian15_135327af:

    # "We sit and I hold her close, trying to provide whatever comfort I can."
    "On s’assoit et je la serre contre moi, essayant de lui apporter tout le réconfort possible."

# game/Scenes/Adrian/adrian15.rpy:302
translate french adrian15_fa24fdf7:

    # gg "I'm sorry I'm being such a bummer. This was supposed to be a fun day."
    gg "Désolée d’avoir cassé l'ambiance. C’était censé être une journée sympa."

# game/Scenes/Adrian/adrian15.rpy:303
translate french adrian15_cfd80ee8:

    # pc "It's okay, Adrian. I'm here for you. Whatever you need."
    pc "C’est pas grave, Adrian. Je suis là pour toi, de la manière qu'il faudra."

# game/Scenes/Adrian/adrian15.rpy:304
translate french adrian15_64ee3ae6:

    # gg "Thanks, [pcname]. I just need a friend really."
    gg "Merci, [pcname]. Là, j’ai surtout besoin d’un ami."

# game/Scenes/Adrian/adrian15.rpy:306
translate french adrian15_d41d8cd9:

    # voice 'voices/adrian_whenitransitioned.mp3'
    voice 'voices/adrian_whenitransitioned.mp3'

# game/Scenes/Adrian/adrian15.rpy:307
translate french adrian15_ec81d936:

    # gg "When I transitioned, besides my mom, Athena was the only person who was there for me."
    gg "Quand j’ai fait ma transition, à part ma mère, Athena était la seule qui était là pour moi."

# game/Scenes/Adrian/adrian15.rpy:309
translate french adrian15_d41d8cd9_1:

    # voice 'voices/adrian_nohesitation.mp3'
    voice 'voices/adrian_nohesitation.mp3'

# game/Scenes/Adrian/adrian15.rpy:310
translate french adrian15_b76e91f4:

    # gg "No hesitation, no questions, just a ton of support and love."
    gg "Pas d’hésitation, pas de questions, rien que plein de soutien et d’amour."

# game/Scenes/Adrian/adrian15.rpy:312
translate french adrian15_d41d8cd9_2:

    # voice 'voices/adrian_shewastheonly.mp3'
    voice 'voices/adrian_shewastheonly.mp3'

# game/Scenes/Adrian/adrian15.rpy:313
translate french adrian15_5be20e3b:

    # gg "She was the only friend I had for a long time."
    gg "Elle a été ma seule amie pendant très longtemps."

# game/Scenes/Adrian/adrian15.rpy:317
translate french adrian15_d41d8cd9_3:

    # voice 'voices/adrian_untilyou.mp3'
    voice 'voices/adrian_untilyou.mp3'

# game/Scenes/Adrian/adrian15.rpy:318
translate french adrian15_b79560a9:

    # gg "Until you."
    gg "Jusqu’à toi."

# game/Scenes/Adrian/adrian15.rpy:320
translate french adrian15_d41d8cd9_4:

    # voice 'voices/adrian_missherlikecrazy.mp3'
    voice 'voices/adrian_missherlikecrazy.mp3'

# game/Scenes/Adrian/adrian15.rpy:321
translate french adrian15_65372d0d:

    # gg "So, I'm going to miss her like crazy, and I'm going to worry about her until I hear from her again."
    gg "Elle va me manquer à en crever, et je vais m’inquiéter pour elle jusqu’à ce que j’aie de ses nouvelles."

# game/Scenes/Adrian/adrian15.rpy:323
translate french adrian15_d41d8cd9_5:

    # voice 'voices/adrian_butimsoglad.mp3'
    voice 'voices/adrian_butimsoglad.mp3'

# game/Scenes/Adrian/adrian15.rpy:324
translate french adrian15_4de0338c:

    # gg "But I'm so glad that you're here."
    gg "Mais je suis tellement contente que tu sois là."

# game/Scenes/Adrian/adrian15.rpy:326
translate french adrian15_d41d8cd9_6:

    # voice 'voices/adrian_iloveyou1.mp3'
    voice 'voices/adrian_iloveyou1.mp3'

# game/Scenes/Adrian/adrian15.rpy:327
translate french adrian15_9c8fbba1:

    # gg "I love you, [pcname]."
    gg "Je t'aime, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:330
translate french adrian15_456cffdf:

    # pc "I love you too, Adrian."
    pc "Je t'aime aussi, Adrian."

# game/Scenes/Adrian/adrian15.rpy:333
translate french adrian15_e9e54f9a:

    # "We sit and watch the sun set, holding each other, enjoying the quiet evening."
    "On s'assoit et on regarde le soleil se coucher, enlacés, en profitant du calme de la soirée."

# game/Scenes/Adrian/adrian15.rpy:334
translate french adrian15_5a0d166e:

    # "I just want to be whatever she needs now."
    "Je veux être tout ce dont elle a besoin en ce moment."

# game/Scenes/Adrian/adrian15.rpy:335
translate french adrian15_46b97a11:

    # "I realize how hard I've fallen for her. I'd do anything to make her happy."
    "Je réalise à quel point je suis tombé amoureux d'elle. Je ferais n'importe quoi pour la rendre heureuse."

# game/Scenes/Adrian/adrian15.rpy:338
translate french adrian15_7f8ffd28:

    # "After the sun sets, we drive back to her house."
    "Une fois le soleil couché, on rentre chez elle en voiture."

# game/Scenes/Adrian/adrian15.rpy:341
translate french adrian15_78e6be93:

    # gg "It looks like my mom is home now. I'm going to have to explain everything to her."
    gg "On dirait que ma mère est rentrée. Je vais devoir tout lui expliquer."

# game/Scenes/Adrian/adrian15.rpy:342
translate french adrian15_f3610339:

    # gg "This is not going to be fun."
    gg "Ça va pas être drôle."

# game/Scenes/Adrian/adrian15.rpy:343
translate french adrian15_20cd9dd9:

    # pc "Want some backup?"
    pc "Tu veux que je vienne ?"

# game/Scenes/Adrian/adrian15.rpy:344
translate french adrian15_0c91a1a8:

    # gg "No, I think I better do this on my own."
    gg "Non, je pense qu'il vaut mieux que je le fasse toute seule."

# game/Scenes/Adrian/adrian15.rpy:345
translate french adrian15_cf913627:

    # gg "Thanks for everything though, [pcname]. You've been amazing."
    gg "Merci quand même pour tout, [pcname]. Tu as été formidable."

# game/Scenes/Adrian/adrian15.rpy:346
translate french adrian15_c46a0b54:

    # pc "Any time."
    pc "De rien."

# game/Scenes/Adrian/adrian15.rpy:347
translate french adrian15_ee13ba27:

    # gg "I'll call you soon, okay?"
    gg "Je t’appelle bientôt, d’accord ?"

# game/Scenes/Adrian/adrian15.rpy:350
translate french adrian15_1f2a71e7:

    # pc "Okay. Good night, Adrian."
    pc "D’accord. Bonne nuit, Adrian."

# game/Scenes/Adrian/adrian15.rpy:351
translate french adrian15_f27d9018:

    # gg "Good night, [pcname]."
    gg "Bonne nuit, [pcname]."

# game/Scenes/Adrian/adrian15.rpy:352
translate french adrian15_80adb898:

    # "I kiss her goodbye."
    "Je l'embrasse pour lui dire au revoir."

# game/Scenes/Adrian/adrian15.rpy:355
translate french adrian15_0cbac92b:

    # "Then I get in my car and drive away, hoping that everything will be okay."
    "Puis je monte dans ma voiture et je pars, en espérant que tout ira bien."

# game/Scenes/Adrian/adrian15.rpy:356
translate french adrian15_339d053a:

    # "And if she needs me, I'll do anything I can to help her."
    "Et si elle a besoin de moi, je ferai tout ce que je peux pour l'aider."

translate french strings:

    # game/Scenes/Adrian/adrian15.rpy:6
    old "After you have checked out a local arcade with Adrian,"
    new "Après avoir découvert une salle d'arcade locale avec Adrian,"

    # game/Scenes/Adrian/adrian15.rpy:7
    old "she will call and invite you to hang out in the afternoon on the weekend."
    new "elle t'appellera pour t'inviter chez elle un après-midi de week-end."

    # game/Scenes/Adrian/adrian15.rpy:28
    old "Oh heck yeah"
    new "Oh oui, carrément"

